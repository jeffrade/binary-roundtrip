# =============================================================================
# .gitignore — Binary Roundtrip
# =============================================================================
# Build artifacts generated by module Makefiles. Run `make clean` to remove.
# =============================================================================

# --- Build output directories (modules 02, 05, 06, 07, 08, 10) ---
build/
bin/

# --- C compilation artifacts ---
*.o
*.i
*.s

# --- Shared libraries ---
*.so
*.so.*
*.a

# --- Java class files ---
*.class

# --- Rust intermediate outputs (--emit=llvm-ir, --emit=mir) ---
*.ll
*.mir

# --- Ruby C extension build artifacts (module 09) ---
ruby/c_extension/Makefile
ruby/c_extension/mkmf.log
ruby/c_extension/*.bundle

# --- Module 01: named binaries built in c/ and rust/ ---
modules/01-execution-models/c/hello
modules/01-execution-models/rust/hello_rust
modules/01-execution-models/rust/execution_compare

# --- Module 03: named binaries and libs built in c/ and rust/ ---
modules/03-elf-binary-format/c/elf_explorer
modules/03-elf-binary-format/c/static_vs_dynamic
modules/03-elf-binary-format/c/dynamic_binary
modules/03-elf-binary-format/c/static_binary
modules/03-elf-binary-format/c/use_libmath
modules/03-elf-binary-format/rust/elf_sections

# --- Module 04: named binaries built in c/ and rust/ ---
modules/04-assembly-fundamentals/c/simple_math
modules/04-assembly-fundamentals/c/calling_convention
modules/04-assembly-fundamentals/c/stack_frames
modules/04-assembly-fundamentals/c/control_flow
modules/04-assembly-fundamentals/rust/assembly_compare

# --- GDB artifacts ---
.gdb_history

# --- Editor / OS noise ---
*~
*.swp
*.swo
.DS_Store
